{
  "name": "macos-vision-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping Apple Vision Framework for local OCR and image analysis — no cloud, no API keys.",
  "type": "module",
  "bin": {
    "macos-vision-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0",
    "os": ["darwin"]
  },
  "keywords": [
    "mcp",
    "macos",
    "ocr",
    "apple-vision",
    "claude",
    "offline",
    "local"
  ],
  "author": "Adrian Wolczuk",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "release": "release-it"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "macos-vision": "^1.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "release-it": "^17.0.0",
    "@release-it/conventional-changelog": "^8.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0"
  }
}
